{
  "name": "w7s-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "local:dev": "node packages/w7s-local/bin/w7s-local.js",
    "deploy": "wrangler deploy",
    "prepare:cloudflare": "node scripts/prepare-cloudflare-config.mjs",
    "reconcile:cloudflare-routes": "node scripts/reconcile-cloudflare-routes.mjs",
    "limits:get": "node scripts/usage-limit-policy.mjs get",
    "limits:set": "node scripts/usage-limit-policy.mjs set",
    "limits:delete": "node scripts/usage-limit-policy.mjs delete",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@babel/standalone": "^7.28.5",
    "fflate": "^0.8.2",
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260522.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "wrangler": "^4.46.0"
  }
}
